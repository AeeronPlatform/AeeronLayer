# Aeeron Gateway — environment variables
  # Copy to .env and fill in values. Never commit .env.

  # ── Server ────────────────────────────────────────────────────────────────────
  PORT=5000
  NODE_ENV=development

  # ── Database ──────────────────────────────────────────────────────────────────
  DATABASE_URL=postgresql://user:password@localhost:5432/aeeron

  # ── Solana ────────────────────────────────────────────────────────────────────
  SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
  # $AEERON SPL token mint — pump.fun deployment (mainnet, do not change):
  AEERON_MINT=DLnWxjvV9rYFgyScBGH7eFtsQqDtyeDsaQTxynnRpump

  # ── x402 ──────────────────────────────────────────────────────────────────────
  X402_MAX_PRICE_LAMPORTS=10000000

  # ── Auth ──────────────────────────────────────────────────────────────────────
  SESSION_SECRET=change_me_in_production
  JWT_SECRET=change_me_in_production
  